# =============================================================
# Board Meeting Minutes Manager — Environment Variables
# =============================================================
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to version control.
# =============================================================


# -------------------------------------------------------------
# PostgreSQL Configuration
# -------------------------------------------------------------
POSTGRES_DB=board_meeting_db
POSTGRES_USER=board_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_PORT=5432


# -------------------------------------------------------------
# Spring Boot Server
# -------------------------------------------------------------
SERVER_PORT=8080


# -------------------------------------------------------------
# Spring Datasource (used when running locally without Docker)
# -------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/board_meeting_db
SPRING_DATASOURCE_USERNAME=board_user
SPRING_DATASOURCE_PASSWORD=your_strong_password_here


# -------------------------------------------------------------
# Flyway
# -------------------------------------------------------------
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=classpath:db/migration


# -------------------------------------------------------------
# JPA / Hibernate
# -------------------------------------------------------------
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false


# -------------------------------------------------------------
# AI Integration (OpenAI / custom LLM)
# -------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048


# -------------------------------------------------------------
# Security / JWT
# -------------------------------------------------------------
JWT_SECRET=replace_with_a_very_long_random_secret_key_min_256_bits
JWT_EXPIRATION_MS=86400000


# -------------------------------------------------------------
# Logging
# -------------------------------------------------------------
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BOARDMEETING=DEBUG
